# 🪨 STRATICA Environment Variables
# Stratigraphic Pattern Recognition & Paleoclimatic Temporal Reconstruction
# Copy to .env and fill in your values

# Database
DB_PASSWORD=your_secure_password_here

# External APIs
PANGAEA_API_KEY=your_pangaea_api_key_here
NOAA_PALEOCLIMATE_KEY=your_noaa_key_here
IODP_ACCESS_TOKEN=your_iodp_token_here

# Security
JWT_SECRET=your_jwt_secret_key_here
SECRET_KEY=your_django_flask_secret_key_here

# Server
STRATICA_HOST=0.0.0.0
STRATICA_PORT=8000
STRATICA_DASHBOARD_PORT=8501

# Logging
LOG_LEVEL=INFO

# Development
FLASK_ENV=development
DEBUG=true

# Production (uncomment in production)
# FLASK_ENV=production
# DEBUG=false
# STRATICA_CONFIG=/etc/stratica/config.yaml

# 🪨 The Earth's stratigraphic column is a 4.5-billion-year journal written in rock.
